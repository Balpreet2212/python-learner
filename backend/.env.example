# PyQuest backend environment variables
# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# App
APP_ENV=development                         # development | production
SECRET_KEY=change-me-in-production          # Random 32+ char string
DOMAIN=pyquest.local

# Database
# Development default: SQLite (auto-created)
DATABASE_URL=sqlite+aiosqlite:///./pyquest_dev.db
# Production example (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/pyquest

# Email
# "console" prints emails to stdout; swap to "resend" with a real key for production
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=noreply@pyquest.local

# Billing
# "stub" logs billing events; swap to "stripe" with real keys for production
BILLING_PROVIDER=stub
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Content
CONTENT_VERSION=local
CONTENT_BASE_URL=/content
